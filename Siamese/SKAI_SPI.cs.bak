        /// <summary>
        /// 현재 선택된 테스트 모드(수동/자동/명령어)를 관리하기 위한 열거형입니다.
        /// </summary>
        public enum COMBOBOX_ITEMS
        {
            MANUAL,
            AUTO,
            CMD,
        }

        // 8x5 크기의 비트맵 폰트 데이터 (알파벳 대문자 및 숫자)
