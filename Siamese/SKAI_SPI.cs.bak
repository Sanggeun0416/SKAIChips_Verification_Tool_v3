namespace SKAI_SPI
{
    public class Lyon : ChipControl
    {
        #region Variable and declaration

        /// <summary>
        /// UI의 테스트 콤보박스에 표시될 수동 테스트 항목을 정의합니다.
        /// </summary>
        public enum TEST_ITEMS_MANUAL
        {
            JUWON,
            NUM_TEST_ITEMS,
        }

        /// <summary>
        /// UI의 테스트 콤보박스에 표시될 자동 테스트 항목을 정의합니다.
        /// </summary>
        public enum TEST_ITEMS_AUTO
        {
            NUM_TEST_ITEMS,
        }

        /// <summary>
        /// 현재 선택된 테스트 모드(수동/자동)를 관리하기 위한 열거형입니다.
        /// </summary>
        public enum COMBOBOX_ITEMS
        {
            MANUAL,
            AUTO,
        }

        // SPI 통신을 위한 인터페이스 객체. 부모 폼(RegContForm)으로부터 전달받습니다.
        private JLcLib.Custom.SPI SPI = null;

        // UART 통신을 위한 시리얼 포트 객체. 칩의 디버그 메시지 등을 수신하는 데 사용됩니다.
        private JLcLib.Comn.Serial Serial { get; set; } = new JLcLib.Comn.Serial();

        // 시리얼 데이터 수신 여부를 나타내는 플래그. 비동기 이벤트 처리에 사용됩니다.
        private bool IsSerialReceivedData = false;
        private bool IsRunCal = false;

        /* * 외부 계측 장비 제어를 위한 SCPI(Standard Commands for Programmable Instruments) 객체들입니다.
         * 자동화된 테스트 환경에서 전원 공급기, 멀티미터, 오실로스코프 등을 제어할 때 사용됩니다.
         */
        JLcLib.Instrument.SCPI PowerSupply0 = null;
        JLcLib.Instrument.SCPI DigitalMultimeter0 = null;
        JLcLib.Instrument.SCPI DigitalMultimeter1 = null;
        JLcLib.Instrument.SCPI DigitalMultimeter2 = null;
        JLcLib.Instrument.SCPI DigitalMultimeter3 = null;
        JLcLib.Instrument.SCPI OscilloScope0 = null;
        JLcLib.Instrument.SCPI SpectrumAnalyzer = null;
        JLcLib.Instrument.SCPI TempChamber = null;

        // 현재 UI에 선택된 테스트 모드(MANUAL 또는 AUTO)를 저장하는 변수입니다.
        private COMBOBOX_ITEMS CombBox_Item = COMBOBOX_ITEMS.MANUAL;

        #endregion Variable and declaration

        /// <summary>
        /// Lyon 클래스의 생성자입니다.
        /// RegContForm으로부터 제어에 필요한 객체와 설정을 전달받아 초기화합니다.
        /// </summary>
        /// <param name="form">메인 UI 폼 객체</param>
        public Lyon(RegContForm form) : base(form)
        {
            // 부모 폼의 SPI 객체를 이 클래스에서 사용할 수 있도록 할당합니다.
            SPI = Parent.SPI;

            // 설정 파일(.ini)에서 "Lyon" 섹션의 시리얼 포트 설정을 읽어옵니다.
            Serial.ReadSettingFile(form.IniFile, "Lyon");

            // 시리얼 데이터가 수신될 때마다 Serial_DataReceived 메서드가 호출되도록 이벤트 핸들러를 등록합니다.
            Serial.DataReceived += Serial_DataReceived;

            // 칩의 캘리브레이션 데이터를 저장할 바이트 배열을 초기화합니다.
            CalibrationData = new byte[256];

            /* UI의 테스트 항목 콤보박스를 초기화합니다. */
            // 기본적으로 수동(MANUAL) 테스트 목록을 채워 넣습니다.
            for (int i = 0; i < (int)TEST_ITEMS_MANUAL.NUM_TEST_ITEMS; i++)
                ComboBox_TestItems.Items.Add(((TEST_ITEMS_MANUAL)i).ToString());
            ComboBox_TestItems.SelectedIndex = 0; // 첫 번째 항목을 기본값으로 선택
        }

        /// <summary>
        /// 시리얼 포트로부터 데이터가 수신될 때 호출되는 이벤트 핸들러입니다.
        /// </summary>
        private void Serial_DataReceived(object sender, JLcLib.Comn.RcvEventArgs e)
        {
            // 데이터가 수신되었음을 플래그로 표시합니다.
            IsSerialReceivedData = true;
        }

        /// <summary>
        /// Lyon 칩의 특정 주소에 16비트 데이터를 쓰는 SPI 프로토콜을 구현합니다.
        /// </summary>
        /// <param name="Address">쓰기를 수행할 7비트 레지스터 주소</param>
        /// <param name="Data">쓸 16비트 데이터</param>
        private void WriteRegister(uint Address, uint Data)
        {
            // SPI 통신을 위한 3바이트 패킷을 생성합니다.
            byte[] Bytes = new byte[3];
            byte rwFlag = 1; // 쓰기 동작을 의미하는 플래그 (0b1)

            // Byte 0: [R/W 플래그(1bit)] + [주소(7bit)]
            Bytes[0] = (byte)((rwFlag << 7) | (Address & 0x7F));
            // Byte 1: 데이터의 상위 8비트
            Bytes[1] = (byte)((Data >> 8) & 0xff);
            // Byte 2: 데이터의 하위 8비트
            Bytes[2] = (byte)((Data >> 0) & 0xff);

            // 구성된 3바이트 패킷을 SPI 버스를 통해 전송합니다.
            SPI.WriteBytes(Bytes, 3, true);
        }

        /// <summary>
        /// Lyon 칩의 특정 주소에서 16비트 데이터를 읽어오는 SPI 프로토콜을 구현합니다.
        /// </summary>
        /// <param name="Address">읽기를 수행할 7비트 레지스터 주소</param>
        /// <returns>읽어온 16비트 데이터</returns>
        private uint ReadRegister(uint Address)
        {
            byte rwFlag = 0; // 읽기 동작을 의미하는 플래그 (0b0)
            uint Data = 0xFFFF; // 읽기 실패 시 반환될 기본값

            // 칩에 보낼 1바이트 주소 패킷
            byte[] Bytes = new byte[1];
            // 칩으로부터 받을 2바이트 데이터 버퍼
            byte[] Buff = new byte[2];

            // Byte 0: [R/W 플래그(1bit)] + [주소(7bit)]
            Bytes[0] = (byte)((rwFlag << 7) | (Address & 0x7F));

            // 1바이트를 보내고 동시에 2바이트를 읽어옵니다.
            Buff = SPI.WriteAndReadBytes(Bytes, 1, 2);

            // 수신된 2바이트를 하나의 16비트 uint 데이터로 조합합니다.
            Data = (uint)((Buff[0] << 8) | (Buff[1] << 0));

            return Data;
        }

        /// <summary>
        /// Excel 파일에서 읽어온 2차원 배열 데이터를 파싱하여
        /// 애플리케이션에서 사용할 수 있는 RegisterGroup 객체로 변환합니다.
        /// </summary>
        /// <param name="GroupName">레지스터 그룹 이름 (Excel 시트 이름)</param>
        /// <param name="RegData">Excel에서 읽어온 원본 데이터</param>
        /// <returns>파싱된 RegisterGroup 객체</returns>
        public override JLcLib.Chip.RegisterGroup MakeRegisterGroup(string GroupName, string[,] RegData)
        {
            // 이 그룹의 모든 레지스터가 공통으로 사용할 Read/Write 함수를 지정하여 객체를 생성합니다.
            JLcLib.Chip.RegisterGroup rg = new JLcLib.Chip.RegisterGroup(GroupName, WriteRegister, ReadRegister);

            // Excel 시트의 특정 패턴을 찾아 레지스터 정보를 추출합니다.
            for (int xStart = 0; xStart < 3; xStart++)
            {
                for (int Row = 0; Row < RegData.GetLength(0); Row++)
                {
                    // "Bit", "Name", "Default" 키워드가 연속으로 나타나는 행을 레지스터의 시작점으로 간주합니다.
                    if ((RegData[Row, xStart] == "Bit") && (RegData[Row + 1, xStart] == "Name") && (RegData[Row + 2, xStart] == "Default"))
                    {
                        string RegName = null;
                        uint Address = 0;

                        // 레지스터 이름과 주소를 추출합니다. (키워드 바로 윗 행에 위치)
                        string StrAddr = RegData[Row - 1, xStart + 1];
                        if (StrAddr.StartsWith("0x"))
                            StrAddr = StrAddr.Substring(2);
                        Address = uint.Parse(StrAddr, System.Globalization.NumberStyles.HexNumber);
                        RegName = RegData[Row - 1, xStart + 2];

                        // 추출한 정보로 Register 객체를 생성하고 그룹에 추가합니다.
                        JLcLib.Chip.Register reg = rg.Registers.Add(RegName, Address);

                        // 레지스터에 속한 개별 비트 필드(RegisterItem) 정보를 파싱합니다.
                        for (int Column = xStart + 1; Column < RegData.GetLength(1); Column++)
                        {
                            // 유효한 비트 필드인지 확인합니다.
                            if (!((RegData[Row + 2, Column] == "X") || (RegData[Row + 2, Column] == "-") || (RegData[Row + 2, Column] == null) || (RegData[Row + 1, Column] == null)))
                            {
                                string ItemName = null, ItemDesc = null;
                                int UpperBit = 0, LowerBit = 0;
                                uint ItemValue = 0;

                                // 이름, 비트 위치, 기본값을 추출합니다.
                                ItemName = RegData[Row + 1, Column];
                                UpperBit = int.Parse(RegData[Row, Column]);
                                LowerBit = int.Parse(RegData[Row, Column]);
                                ItemValue = (uint)((RegData[Row + 2, Column] == "0") ? 0 : 1);

                                // 여러 비트에 걸친 필드인 경우, LowerBit와 ItemValue를 계속 파싱합니다.
                                for (int x = Column + 1; x < RegData.GetLength(1); x++)
                                {
                                    if (RegData[Row + 1, x] == null) // 이름이 비어있으면 같은 필드에 속한 것으로 간주
                                    {
                                        if (RegData[Row, x] != null)
                                        {
                                            LowerBit = int.Parse(RegData[Row, x]);
                                            ItemValue = (ItemValue << 1) | (uint)((RegData[Row + 2, x] == "0") ? 0 : 1);
                                        }
                                    }
                                    else break;
                                }

                                // 비트 필드에 대한 상세 설명을 파싱합니다.
                                for (int y = Row; y < RegData.GetLength(0); y++)
                                {
                                    if (RegData[y, xStart] == ItemName)
                                    {
                                        ItemDesc = RegData[y, xStart + 1];
                                        // ... (상세 설명 파싱 로직)
                                    }
                                }
                                // 최종적으로 파싱된 정보로 RegisterItem 객체를 생성하고 레지스터에 추가합니다.
                                reg.Items.Add(ItemName, UpperBit, LowerBit, ItemValue, ItemDesc);
                            }
                        }
                    }
                }
            }
            return rg;
        }

        /// <summary>
        /// 메인 UI의 "Chip Specific Control" 그룹 박스를 Lyon 칩에 맞게 설정합니다.
        /// </summary>
        public override void SetChipSpecificUI()
        {
            /*
             * 버튼과 텍스트 박스는 0~11번까지의 인덱스를 가집니다.
             * 이 인덱스를 사용하여 특정 위치의 컨트롤을 활성화하고 기능을 할당합니다.
             */
            Parent.ChipCtrlTextboxes[0].ReadOnly = true;
            Parent.ChipCtrlTextboxes[0].Visible = true;
            Parent.ChipCtrlTextboxes[0].Text = Serial.Config.PortName;
            Parent.ChipCtrlTextboxes[0].Size = new System.Drawing.Size(Parent.ChipCtrlTextboxes[0].Size.Width * 2 + 3, Parent.ChipCtrlTextboxes[0].Size.Height);

            Parent.ChipCtrlButtons[2].Text = "Connect";
            Parent.ChipCtrlButtons[2].Visible = true;
            Parent.ChipCtrlButtons[2].Click += SerialConnect_Click; // 시리얼 연결 버튼 이벤트 할당

            Parent.ChipCtrlButtons[3].Text = "Set UART";
            Parent.ChipCtrlButtons[3].Visible = true;
            Parent.ChipCtrlButtons[3].Click += SerialSetting_Click; // 시리얼 설정 버튼 이벤트 할당

            Parent.ChipCtrlButtons[8].Text = "Manual";
            Parent.ChipCtrlButtons[8].Visible = true;
            Parent.ChipCtrlButtons[8].Click += Change_To_Manual_Test_Items; // 수동 테스트 모드 전환 버튼

            Parent.ChipCtrlButtons[9].Text = "AUTO";
            Parent.ChipCtrlButtons[9].Visible = true;
            Parent.ChipCtrlButtons[9].Click += Change_To_Auto_Test_Items; // 자동 테스트 모드 전환 버튼
        }

        /// <summary>
        /// 시리얼 포트 연결/해제 버튼 클릭 이벤트 핸들러입니다.
        /// </summary>
        private void SerialConnect_Click(object sender, EventArgs e)
        {
            Button b = sender as Button;
            if (Serial.IsOpen == false)
            {
                Serial.Open();
                if (Serial.IsOpen)
                {
                    b.Text = "Disconn";
                    Parent.ChipCtrlTextboxes[0].Text = Serial.Config.PortName + "-" + Serial.Config.BaudRate.ToString();
                }
            }
            else
            {
                Serial.Close();
                if (!Serial.IsOpen)
                    b.Text = "Connect";
            }
        }

        /// <summary>
        /// 시리얼 포트 설정 창을 여는 버튼 클릭 이벤트 핸들러입니다.
        /// </summary>
        private void SerialSetting_Click(object sender, EventArgs e)
        {
            JLcLib.Comn.WireComnForm.Show(Serial);
            Serial.WriteSettingFile(Parent.IniFile, "Lyon");
        }

        /// <summary>
        /// 테스트 콤보박스를 '수동' 모드 항목으로 변경합니다.
        /// </summary>
        private void Change_To_Manual_Test_Items(object sender, EventArgs e)
        {
            CombBox_Item = COMBOBOX_ITEMS.MANUAL;
            ComboBox_TestItems.Items.Clear();
            for (int i = 0; i < (int)TEST_ITEMS_MANUAL.NUM_TEST_ITEMS; i++)
                ComboBox_TestItems.Items.Add(((TEST_ITEMS_MANUAL)i).ToString());
            ComboBox_TestItems.SelectedIndex = 0;
        }

        /// <summary>
        /// 테스트 콤보박스를 '자동' 모드 항목으로 변경합니다.
        /// </summary>
        private void Change_To_Auto_Test_Items(object sender, EventArgs e)
        {
            CombBox_Item = COMBOBOX_ITEMS.AUTO;
            ComboBox_TestItems.Items.Clear();
            for (int i = 0; i < (int)TEST_ITEMS_AUTO.NUM_TEST_ITEMS; i++)
                ComboBox_TestItems.Items.Add(((TEST_ITEMS_AUTO)i).ToString());
            ComboBox_TestItems.SelectedIndex = 0;
        }

        /// <summary>
        /// 메인 폼의 'Run Log' 버튼 활성화 여부를 결정하기 위해 호출됩니다.
        /// </summary>
        /// <returns>시리얼 포트가 열려 있으면 true를 반환합니다.</returns>
        public override bool CheckConnectionForLog()
        {
            return ((Serial != null) && Serial.IsOpen);
        }

        /// <summary>
        /// 'Run Log' 기능이 활성화되었을 때 주기적으로 호출되어 시리얼 데이터를 처리합니다.
        /// </summary>
        public override void RunLog()
        {
            if (Serial.IsOpen && (Serial.RcvQueue.Count != 0))
            {
                // 수신 큐에 있는 모든 데이터를 읽어와 로그 창에 표시합니다.
                for (int i = 0; i < Serial.RcvQueue.Count; i++)
                {
                    byte b = Serial.RcvQueue.Get();
                    if ((b > 0x00 && b < 0x80) && b != '\0')
                    {
                        LogMessage += (char)b;
                        if (b == '\n') // 개행 문자를 만나면 한 줄로 처리하여 출력
                        {
                            Log.WriteWithElapsedTime(LogMessage);
                            Log.WriteLine("\n");
                            LogMessage = "";
                        }
                    }
                }
            }
        }

        /// <summary>
        /// 메인 폼의 커맨드 입력창에서 받은 문자열을 시리얼 포트로 전송합니다.
        /// </summary>
        /// <param name="Command">전송할 명령어 문자열</param>
        public override void SendCommand(string Command)
        {
            Command += "\r\n"; // 명령어 끝에 CR+LF 추가
            byte[] Var = Encoding.ASCII.GetBytes(Command);
            Serial.WriteBytes(Var, Var.Length, true);
        }

        /// <summary>
        /// 메인 폼의 'Run Test' 버튼을 눌렀을 때 호출되는 메인 테스트 실행 함수입니다.
        /// </summary>
        /// <param name="TestItemIndex">콤보박스에서 선택된 테스트 항목의 인덱스</param>
        /// <param name="Arg">테스트에 필요한 인자값 문자열</param>
        public override void RunTest(int TestItemIndex, string Arg)
        {
            int iVal;
            try { iVal = int.Parse(Arg, System.Globalization.NumberStyles.Number); }
            catch { iVal = 0; }

            // 현재 선택된 모드(MANUAL/AUTO)에 따라 분기합니다.
            switch (CombBox_Item)
            {
                case COMBOBOX_ITEMS.MANUAL:
                    // 선택된 수동 테스트 항목에 따라 해당 테스트 함수를 호출합니다.
                    switch ((TEST_ITEMS_MANUAL)TestItemIndex)
                    {
                        case TEST_ITEMS_MANUAL.JUWON:
                            if (Arg == "")
                            {
                                Log.WriteLine("시작할 값을 텍스트상자에 10진수로 적어주세요. (0~511)");
                            }
                            else
                            {
                                Log.WriteLine("Start : " + Arg);
                                Write_Register_for_juwon(iVal);
                            }
                            break;
                        default:
                            break;
                    }
                    break;
                case COMBOBOX_ITEMS.AUTO:
                    // 자동 테스트 로직 구현
                    break;
                default:
                    break;
            }
        }

        #region Function for Chip Test
        /// <summary>
        /// 'JUWON' 테스트 항목에 대한 실제 동작을 정의하는 함수입니다.
        /// </summary>
        /// <param name="iVal">테스트 시작 값</param>
        private void Write_Register_for_juwon(int iVal)
        {
            // 레지스터 맵에서 "ZCD_DELAY_TRIM_SEL<8:0>" 이름의 비트 필드를 가져옵니다.
            RegisterItem ZCD_DELAY_TRIM_SEL = Parent.RegMgr.GetRegisterItem("ZCD_DELAY_TRIM_SEL<8:0>");

            // 입력받은 값(iVal)부터 0까지 1씩 감소시키면서 해당 레지스터에 값을 씁니다.
            for (int i = iVal; i >= 0; i--)
            {
                ZCD_DELAY_TRIM_SEL.Value = (uint)i;
                ZCD_DELAY_TRIM_SEL.Write(); // 설정된 값을 칩에 실제로 씀
            }
        }
        #endregion
    }

    public class Salus8 : ChipControl
    {
        #region Variable and declaration

        /// <summary>
        /// UI의 테스트 콤보박스에 표시될 수동 테스트 항목을 정의합니다.
        /// </summary>
        public enum TEST_ITEMS_MANUAL
        {
            TEST,
            NUM_TEST_ITEMS,
        }

        /// <summary>
        /// UI의 테스트 콤보박스에 표시될 자동 테스트 항목을 정의합니다.
        /// </summary>
        public enum TEST_ITEMS_AUTO
        {
            TEST,
            NUM_TEST_ITEMS,
        }

        /// <summary>
        /// 현재 선택된 테스트 모드(수동/자동)를 관리하기 위한 열거형입니다.
        /// </summary>
        public enum COMBOBOX_ITEMS
        {
            MANUAL,
            AUTO,
        }

        // SPI 통신을 위한 인터페이스 객체. 부모 폼(RegContForm)으로부터 전달받습니다.
        private JLcLib.Custom.SPI SPI = null;

        // UART 통신을 위한 시리얼 포트 객체.
        private JLcLib.Comn.Serial Serial { get; set; } = new JLcLib.Comn.Serial();

        // 시리얼 데이터 수신 여부를 나타내는 플래그.
        private bool IsSerialReceivedData = false;
        private bool IsRunCal = false;

        /* * 외부 계측 장비 제어를 위한 SCPI 객체들입니다. */
        JLcLib.Instrument.SCPI PowerSupply0 = null;
        JLcLib.Instrument.SCPI DigitalMultimeter0 = null;
        JLcLib.Instrument.SCPI DigitalMultimeter1 = null;
        JLcLib.Instrument.SCPI DigitalMultimeter2 = null;
        JLcLib.Instrument.SCPI DigitalMultimeter3 = null;
        JLcLib.Instrument.SCPI OscilloScope0 = null;
        JLcLib.Instrument.SCPI SpectrumAnalyzer = null;
        JLcLib.Instrument.SCPI TempChamber = null;

        // 현재 UI에 선택된 테스트 모드를 저장하는 변수입니다.
        private COMBOBOX_ITEMS CombBox_Item = COMBOBOX_ITEMS.MANUAL;

        #endregion Variable and declaration

        /// <summary>
        /// Salus8 클래스의 생성자입니다.
        /// </summary>
        /// <param name="form">메인 UI 폼 객체</param>
        public Salus8(RegContForm form) : base(form)
        {
            // 부모 폼의 SPI 객체를 할당합니다.
            SPI = Parent.SPI;

            // 설정 파일(.ini)에서 "Salus8" 섹션의 시리얼 포트 설정을 읽어옵니다.
            Serial.ReadSettingFile(form.IniFile, "Salus8");

            // 시리얼 데이터 수신 이벤트 핸들러를 등록합니다.
            Serial.DataReceived += Serial_DataReceived;

            // 캘리브레이션 데이터 배열을 초기화합니다.
            CalibrationData = new byte[256];

            /* UI의 테스트 항목 콤보박스를 초기화합니다. */
            for (int i = 0; i < (int)TEST_ITEMS_MANUAL.NUM_TEST_ITEMS; i++)
                ComboBox_TestItems.Items.Add(((TEST_ITEMS_MANUAL)i).ToString());
            ComboBox_TestItems.SelectedIndex = 0;
        }

        /// <summary>
        /// 시리얼 포트로부터 데이터가 수신될 때 호출되는 이벤트 핸들러입니다.
        /// </summary>
        private void Serial_DataReceived(object sender, JLcLib.Comn.RcvEventArgs e)
        {
            IsSerialReceivedData = true;
        }

        /// <summary>
        /// Salus8 칩의 특정 주소에 16비트 데이터를 쓰는 SPI 프로토콜을 구현합니다.
        /// </summary>
        /// <param name="Address">쓰기를 수행할 7비트 레지스터 주소</param>
        /// <param name="Data">쓸 16비트 데이터</param>
        private void WriteRegister(uint Address, uint Data)
        {
            byte[] Bytes = new byte[3];
            byte rwFlag = 1; // 쓰기 플래그

            Bytes[0] = (byte)((rwFlag << 7) | (Address & 0x7F));
            Bytes[1] = (byte)((Data >> 8) & 0xff);
            Bytes[2] = (byte)((Data >> 0) & 0xff);

            SPI.WriteBytes(Bytes, 3, true);
        }

        /// <summary>
        /// Salus8 칩의 특정 주소에서 16비트 데이터를 읽어오는 SPI 프로토콜을 구현합니다.
        /// </summary>
        /// <param name="Address">읽기를 수행할 7비트 레지스터 주소</param>
        /// <returns>읽어온 16비트 데이터</returns>
        private uint ReadRegister(uint Address)
        {
            byte rwFlag = 0; // 읽기 플래그
            uint Data = 0xFFFF;
            byte[] Bytes = new byte[1];
            byte[] Buff = new byte[2];

            Bytes[0] = (byte)((rwFlag << 7) | (Address & 0x7F));

            Buff = SPI.WriteAndReadBytes(Bytes, 1, 2);

            Data = (uint)((Buff[0] << 8) | (Buff[1] << 0));

            return Data;
        }

        /// <summary>
        /// Excel 데이터를 파싱하여 RegisterGroup 객체로 변환합니다.
        /// </summary>
        /// <param name="GroupName">레지스터 그룹 이름</param>
        /// <param name="RegData">Excel 원본 데이터</param>
        /// <returns>파싱된 RegisterGroup 객체</returns>
        public override JLcLib.Chip.RegisterGroup MakeRegisterGroup(string GroupName, string[,] RegData)
        {
            JLcLib.Chip.RegisterGroup rg = new JLcLib.Chip.RegisterGroup(GroupName, WriteRegister, ReadRegister);

            for (int xStart = 0; xStart < 3; xStart++)
            {
                for (int Row = 0; Row < RegData.GetLength(0); Row++)
                {
                    if ((RegData[Row, xStart] == "Bit") && (RegData[Row + 1, xStart] == "Name") && (RegData[Row + 2, xStart] == "Default"))
                    {
                        string RegName = null;
                        uint Address = 0;

                        string StrAddr = RegData[Row - 1, xStart + 1];
                        if (StrAddr.StartsWith("0x"))
                            StrAddr = StrAddr.Substring(2);
                        Address = uint.Parse(StrAddr, System.Globalization.NumberStyles.HexNumber);
                        RegName = RegData[Row - 1, xStart + 2];

                        JLcLib.Chip.Register reg = rg.Registers.Add(RegName, Address);

                        for (int Column = xStart + 1; Column < RegData.GetLength(1); Column++)
                        {
                            if (!((RegData[Row + 2, Column] == "X") || (RegData[Row + 2, Column] == "-") || (RegData[Row + 2, Column] == null) || (RegData[Row + 1, Column] == null)))
                            {
                                string ItemName = null, ItemDesc = null;
                                int UpperBit = 0, LowerBit = 0;
                                uint ItemValue = 0;

                                ItemName = RegData[Row + 1, Column];
                                UpperBit = int.Parse(RegData[Row, Column]);
                                LowerBit = int.Parse(RegData[Row, Column]);
                                ItemValue = (uint)((RegData[Row + 2, Column] == "0") ? 0 : 1);

                                for (int x = Column + 1; x < RegData.GetLength(1); x++)
                                {
                                    if (RegData[Row + 1, x] == null)
                                    {
                                        if (RegData[Row, x] != null)
                                        {
                                            LowerBit = int.Parse(RegData[Row, x]);
                                            ItemValue = (ItemValue << 1) | (uint)((RegData[Row + 2, x] == "0") ? 0 : 1);
                                        }
                                    }
                                    else break;
                                }

                                for (int y = Row; y < RegData.GetLength(0); y++)
                                {
                                    if (RegData[y, xStart] == ItemName)
                                    {
                                        ItemDesc = RegData[y, xStart + 1];
                                        // ... (상세 설명 파싱 로직)
                                    }
                                }
                                reg.Items.Add(ItemName, UpperBit, LowerBit, ItemValue, ItemDesc);
                            }
                        }
                    }
                }
            }
            return rg;
        }

        /// <summary>
        /// Salus8 칩에 특화된 UI를 설정합니다. 현재는 비어 있습니다.
        /// </summary>
        public override void SetChipSpecificUI()
        {
            /*
             * 이 공간에 Salus8 칩에만 필요한 버튼이나 텍스트 박스 등의 UI 컨트롤을
             * 활성화하고 이벤트 핸들러를 할당하는 코드를 작성합니다.
             */
        }

        /// <summary>
        /// 시리얼 포트 연결/해제 버튼 클릭 이벤트 핸들러입니다.
        /// </summary>
        private void SerialConnect_Click(object sender, EventArgs e)
        {
            Button b = sender as Button;
            if (Serial.IsOpen == false)
            {
                Serial.Open();
                if (Serial.IsOpen)
                {
                    b.Text = "Disconn";
                    Parent.ChipCtrlTextboxes[0].Text = Serial.Config.PortName + "-" + Serial.Config.BaudRate.ToString();
                }
            }
            else
            {
                Serial.Close();
                if (!Serial.IsOpen)
                    b.Text = "Connect";
            }
        }

        /// <summary>
        /// 시리얼 포트 설정 창을 여는 버튼 클릭 이벤트 핸들러입니다.
        /// </summary>
        private void SerialSetting_Click(object sender, EventArgs e)
        {
            JLcLib.Comn.WireComnForm.Show(Serial);
            Serial.WriteSettingFile(Parent.IniFile, "Salus8");
        }

        /// <summary>
        /// 테스트 콤보박스를 '수동' 모드 항목으로 변경합니다.
        /// </summary>
        private void Change_To_Manual_Test_Items(object sender, EventArgs e)
        {
            CombBox_Item = COMBOBOX_ITEMS.MANUAL;
            ComboBox_TestItems.Items.Clear();
            for (int i = 0; i < (int)TEST_ITEMS_MANUAL.NUM_TEST_ITEMS; i++)
                ComboBox_TestItems.Items.Add(((TEST_ITEMS_MANUAL)i).ToString());
            ComboBox_TestItems.SelectedIndex = 0;
        }

        /// <summary>
        /// 테스트 콤보박스를 '자동' 모드 항목으로 변경합니다.
        /// </summary>
        private void Change_To_Auto_Test_Items(object sender, EventArgs e)
        {
            CombBox_Item = COMBOBOX_ITEMS.AUTO;
            ComboBox_TestItems.Items.Clear();
            for (int i = 0; i < (int)TEST_ITEMS_AUTO.NUM_TEST_ITEMS; i++)
                ComboBox_TestItems.Items.Add(((TEST_ITEMS_AUTO)i).ToString());
            ComboBox_TestItems.SelectedIndex = 0;
        }

        /// <summary>
        /// 'Run Log' 버튼 활성화 여부를 결정합니다.
        /// </summary>
        public override bool CheckConnectionForLog()
        {
            return ((Serial != null) && Serial.IsOpen);
        }

        /// <summary>
        /// 시리얼 데이터를 처리하여 로그 창에 표시합니다.
        /// </summary>
        public override void RunLog()
        {
            if (Serial.IsOpen && (Serial.RcvQueue.Count != 0))
            {
                for (int i = 0; i < Serial.RcvQueue.Count; i++)
                {
                    byte b = Serial.RcvQueue.Get();
                    if ((b > 0x00 && b < 0x80) && b != '\0')
                    {
                        LogMessage += (char)b;
                        if (b == '\n')
                        {
                            Log.WriteWithElapsedTime(LogMessage);
                            Log.WriteLine("\n");
                            LogMessage = "";
                        }
                    }
                }
            }
        }

        /// <summary>
        /// 커맨드 입력창의 문자열을 시리얼 포트로 전송합니다.
        /// </summary>
        public override void SendCommand(string Command)
        {
            Command += "\r\n";
            byte[] Var = Encoding.ASCII.GetBytes(Command);
            Serial.WriteBytes(Var, Var.Length, true);
        }

        /// <summary>
        /// 'Run Test' 버튼 클릭 시 호출되는 메인 테스트 함수입니다.
        /// </summary>
        public override void RunTest(int TestItemIndex, string Arg)
        {
            int iVal;
            try { iVal = int.Parse(Arg, System.Globalization.NumberStyles.Number); }
            catch { iVal = 0; }

            switch (CombBox_Item)
            {
                case COMBOBOX_ITEMS.MANUAL:
                    switch ((TEST_ITEMS_MANUAL)TestItemIndex)
                    {
                        // 여기에 수동 테스트 항목에 대한 case를 추가합니다.
                        default:
                            break;
                    }
                    break;
                case COMBOBOX_ITEMS.AUTO:
                    switch ((TEST_ITEMS_AUTO)TestItemIndex)
                    {
                        // 여기에 자동 테스트 항목에 대한 case를 추가합니다.
                        default:
                            break;
                    }
                    break;
                default:
                    break;
            }
        }

        #region Function for Chip Test
        // 이 영역에 Salus8 칩을 위한 테스트 함수들을 구현합니다.
        #endregion
    }

    public class IRIS2 : ChipControl
    {
        #region Variable and declaration

        /// <summary>
